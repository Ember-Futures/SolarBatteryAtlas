{
    "name": "solar-atlas",
    "version": "1.0.0",
    "description": "Solar + Battery Atlas local development environment",
    "scripts": {
        "dev": "vite",
        "start": "vite",
        "build:css": "tailwindcss -c tailwind.config.js -i tailwind.source.css -o deployment/css/tailwind.css --minify",
        "build:dist": "node scripts/build-dist.mjs",
        "build": "npm run build:css && npm run build:dist"
    },
    "devDependencies": {
        "esbuild": "^0.25.12",
        "tailwindcss": "^3.4.17",
        "vite": "^6.0.0"
    }
}
